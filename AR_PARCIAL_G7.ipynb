        "\n",
        "# ---------------- TABLA 2: EVALUACIÓN GREEDY (política final) --------------\n",
        "filas_eval = []\n",
        "for nombre_alg, Q_tabla in [(\"Q-Learning\", Q_QL), (\"SARSA\", Q_SARSA)]:\n",
