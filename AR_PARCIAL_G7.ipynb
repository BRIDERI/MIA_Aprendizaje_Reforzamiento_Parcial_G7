        "ax.set_xlabel(\"Episodio\")\n",
        "ax.set_ylabel(f\"Pasos por episodio (media móvil, {VENTANA} ep.)\")\n",
        "ax.set_title(\"(b) Pasos vs Episodio\", fontweight=\"bold\")\n",
        "ax.legend()\n",
        "\n",
        "# ---------------- (c) TASA DE ÉXITO vs EPISODIO ----------------------------\n",
