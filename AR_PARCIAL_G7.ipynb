        "    mapa[5, :] = MURO      # muro de contención lado sur\n",
        "    mapa[6:9, :] = VIA     # calzada vehicular deprimida\n",
        "    mapa[9, :] = MURO      # muro de contención lado norte\n",
        "\n",
        "    # ================== AV. CANTA CALLAO (vertical, columnas 9-11) ==========\n",
        "    mapa[:, 9:12] = VIA\n",
        "    # Cruces peatonales a nivel de Canta Callao (se mantienen: no se eleva)\n",
        "    mapa[2, 9:12] = VEREDA\n",
        "    mapa[12, 9:12] = VEREDA\n",
