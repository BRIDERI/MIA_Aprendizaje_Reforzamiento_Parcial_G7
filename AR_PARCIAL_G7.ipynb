        "    # ================== ACCESO (a): RAMPA OESTE, columnas 6-7 ===============\n",
        "    # Rampa de subida desde el lado SUR (viene desde fila 10 hacia arriba)\n",
        "    mapa[10, 6:8] = RAMPA   # arranque de rampa sur\n",
